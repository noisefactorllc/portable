#!/usr/bin/env python3
"""
Download pre-built shade-mcp from GitHub Releases and vendor all dist contents.
"""
import os
import shutil
import subprocess
import tempfile
import sys

REPO = "noisedeck/shade-mcp"
VENDOR_DIR = "vendor/shade-mcp"
ASSET_NAME = "shade-mcp-dist.tar.gz"


def download_release(tag, dest_dir):
    """Download and extract the release tarball."""
    tarball = os.path.join(dest_dir, ASSET_NAME)
    token = os.environ.get("GITHUB_TOKEN")

    # Try gh CLI first, fall back to curl
    try:
        cmd = ["gh", "release", "download", tag, "--repo", REPO,
               "--pattern", ASSET_NAME, "--dir", dest_dir]
        subprocess.run(cmd, check=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        print("gh CLI unavailable or failed, falling back to curl...")
        url = f"https://github.com/{REPO}/releases/download/{tag}/{ASSET_NAME}"
        curl_cmd = ["curl", "-fSL", "-o", tarball, url]
        if token:
            curl_cmd[1:1] = ["-H", f"Authorization: Bearer {token}"]
        subprocess.run(curl_cmd, check=True)

    # Extract
    subprocess.run(["tar", "-xzf", tarball, "-C", dest_dir], check=True)
    os.remove(tarball)


def main():
    tag = os.environ.get("SHADE_MCP_TAG")
    if not tag:
        print("SHADE_MCP_TAG is required (e.g. v0.1.0)")
        return 1

    with tempfile.TemporaryDirectory() as tmpdir:
        print(f"Downloading shade-mcp {tag}...")
        download_release(tag, tmpdir)

        print(f"Copying dist to {VENDOR_DIR}...")

        if os.path.exists(VENDOR_DIR):
            shutil.rmtree(VENDOR_DIR)
        os.makedirs(VENDOR_DIR, exist_ok=True)

        # Copy all dist contents (MCP server binary + library entry points)
        for item in os.listdir(tmpdir):
            src = os.path.join(tmpdir, item)
            dst = os.path.join(VENDOR_DIR, item)
            if os.path.isdir(src):
                shutil.copytree(src, dst)
                print(f"  + {item}/")
            else:
                shutil.copy2(src, dst)
                print(f"  + {item}")

    print("Done!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
